#!/bin/bash
set -euo pipefail

VERSION="2.0.1"
CONFIG_FILE="${CLAUDEWHO_CONFIG:-$HOME/.claudewho.conf}"
CONFIG_DIR_PREFIX="$HOME/.claudewho-"
WRAPPER_DIR="$HOME/.local/bin"
CURRENT_ACCOUNT_FILE="$HOME/.claudewho-current-account"

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    MAGENTA='\033[0;35m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
    # Claude orange #C15F3C
    ORANGE='\033[38;2;193;95;60m'
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    MAGENTA=''
    CYAN=''
    BOLD=''
    DIM=''
    NC=''
    ORANGE=''
fi

# Ensure config file exists
touch_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        touch "$CONFIG_FILE"
    fi
}

# Get all registered accounts
get_accounts() {
    touch_config
    cat "$CONFIG_FILE" 2>/dev/null | grep -v '^$' | sort -u || true
}

# Check if account exists in config
account_exists() {
    local name="$1"
    get_accounts | grep -qx "$name"
}

# Validate account name
validate_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        echo -e "${RED}Error:${NC} Invalid account name '$name'"
        echo "Names must be lowercase, start with a letter/number, and contain only letters, numbers, and hyphens."
        exit 1
    fi
    if [[ ${#name} -gt 50 ]]; then
        echo -e "${RED}Error:${NC} Account name too long (max 50 characters)"
        exit 1
    fi
}

# Check if ~/.local/bin is in PATH
check_path() {
    if [[ ":$PATH:" != *":$WRAPPER_DIR:"* ]]; then
        return 1
    fi
    return 0
}

# Create wrapper script for an account
create_wrapper() {
    local name="$1"
    local dir="${CONFIG_DIR_PREFIX}${name}"
    local wrapper_path="${WRAPPER_DIR}/claudewho-${name}"

    # Ensure wrapper directory exists
    mkdir -p "$WRAPPER_DIR"

    # Create the wrapper script
    cat > "$wrapper_path" << EOF
#!/bin/bash
export CLAUDE_CONFIG_DIR="$dir"
exec claude "\$@"
EOF

    chmod +x "$wrapper_path"
}

# Remove wrapper script for an account
remove_wrapper() {
    local name="$1"
    local wrapper_path="${WRAPPER_DIR}/claudewho-${name}"

    if [[ -f "$wrapper_path" ]]; then
        rm -f "$wrapper_path"
    fi
}

# Get current account name
get_current_account() {
    if [[ -f "$CURRENT_ACCOUNT_FILE" ]]; then
        cat "$CURRENT_ACCOUNT_FILE" 2>/dev/null || true
    fi
}

# Create/update the main claude wrapper
create_claude_wrapper() {
    local wrapper_path="${WRAPPER_DIR}/claude"

    mkdir -p "$WRAPPER_DIR"

    cat > "$wrapper_path" << 'WRAPPER_EOF'
#!/bin/bash
# Claude wrapper - managed by claudewho
# This wrapper allows switching accounts with: claudewho use <name>

CURRENT_ACCOUNT_FILE="$HOME/.claudewho-current-account"
CONFIG_DIR_PREFIX="$HOME/.claudewho-"
WRAPPER_DIR="$HOME/.local/bin"

# Find the real claude binary (skip our wrapper)
find_real_claude() {
    local IFS=':'
    for dir in $PATH; do
        # Skip our wrapper directory
        [[ "$dir" == "$WRAPPER_DIR" ]] && continue
        if [[ -x "$dir/claude" ]]; then
            echo "$dir/claude"
            return 0
        fi
    done
    echo "claude"  # fallback
}

# Check for current account
if [[ -f "$CURRENT_ACCOUNT_FILE" ]]; then
    account=$(cat "$CURRENT_ACCOUNT_FILE" 2>/dev/null)
    if [[ -n "$account" ]]; then
        export CLAUDE_CONFIG_DIR="${CONFIG_DIR_PREFIX}${account}"
    fi
fi

# Find and exec real claude
real_claude=$(find_real_claude)
exec "$real_claude" "$@"
WRAPPER_EOF

    chmod +x "$wrapper_path"
}

# Show banner
show_banner() {
    echo ""
    echo -e "${ORANGE} ▄▖▜      ▌                ▗   ${NC}"
    echo -e "${ORANGE} ▌ ▐ ▀▌▌▌▛▌█▌  ▀▌▛▘▛▘▛▌▌▌▛▌▜▘▛▘${NC}"
    echo -e "${ORANGE} ▙▖▐▖█▌▙▌▙▌▙▖  █▌▙▖▙▖▙▌▙▌▌▌▐▖▄▌${NC}"
    echo ""
}

# Show usage
usage() {
    show_banner
    echo -e "${BOLD}USAGE:${NC}"
    echo "    claudewho <command> [arguments]"
    echo ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo "    list                List all configured accounts"
    echo "    add <name>          Create a new account configuration"
    echo "    remove <name>       Remove an account (with confirmation)"
    echo "    use <name>          Switch to an account"
    echo "    shell-init          Print shell aliases (alternative to wrapper scripts)"
    echo "    version             Show version information"
    echo "    help                Show this help message"
    echo ""
    echo -e "${BOLD}QUICK START:${NC}"
    echo "    claudewho add work       # Creates 'work' account"
    echo "    claudewho-work           # Launch Claude with 'work' account"
    echo "    claudewho use work       # Switch default account"
    echo "    claude                   # Uses current account"
    echo ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo "    claudewho add work"
    echo "    claudewho add personal"
    echo "    claudewho list"
    echo "    claudewho-work"
    echo "    claudewho-personal"
    echo ""
    echo -e "${BOLD}VERSION:${NC}"
    echo "    $VERSION"
}

# List all accounts
list_accounts() {
    local accounts
    accounts=$(get_accounts)
    local current
    current=$(get_current_account)

    if [[ -z "$accounts" ]]; then
        echo -e "${YELLOW}No accounts configured.${NC}"
        echo ""
        echo "Create one with:"
        echo "    claudewho add <name>"
        return 0
    fi

    echo -e "${BOLD}Configured Claude accounts:${NC}"
    echo ""

    while IFS= read -r name; do
        local dir="${CONFIG_DIR_PREFIX}${name}"
        local status
        local marker=""

        # Mark current account
        if [[ "$name" == "$current" ]]; then
            marker="${GREEN}*${NC} "
        else
            marker="  "
        fi

        if [[ -d "$dir" ]]; then
            # Check if authenticated by looking for credentials
            if [[ -f "$dir/.claude.json" ]] || [[ -f "$dir/.credentials.json" ]] || [[ -f "$dir/credentials.json" ]]; then
                status="${GREEN}authenticated${NC}"
            else
                status="${YELLOW}not authenticated${NC}"
            fi
        else
            status="${RED}directory missing${NC}"
        fi

        printf "${marker}${BLUE}%-20s${NC} %-30s (%b)\n" "$name" "$dir" "$status"
    done <<< "$accounts"

    echo ""
    if [[ -n "$current" ]]; then
        echo -e "${GREEN}*${NC} = current account"
        echo ""
    fi
    echo -e "Switch with ${BOLD}claudewho use <name>${NC}"
}

# Add a new account
add_account() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo -e "${RED}Error:${NC} Account name required"
        echo "Usage: claudewho add <name>"
        exit 1
    fi

    validate_name "$name"

    if account_exists "$name"; then
        echo -e "${RED}Error:${NC} Account '$name' already exists"
        exit 1
    fi

    local dir="${CONFIG_DIR_PREFIX}${name}"

    if [[ -d "$dir" ]]; then
        echo -e "${YELLOW}Warning:${NC} Directory $dir already exists"
        read -rp "Register this existing directory as account '$name'? [y/N] " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo "Aborted."
            exit 0
        fi
    else
        mkdir -p "$dir"
        echo -e "${GREEN}Created${NC} $dir"
    fi

    # Register the account
    touch_config
    echo "$name" >> "$CONFIG_FILE"

    # Create wrapper script
    create_wrapper "$name"
    echo -e "${GREEN}Created${NC} ${WRAPPER_DIR}/claudewho-${name}"

    echo -e "${GREEN}Account '$name' added successfully!${NC}"
    echo ""

    # Check if ~/.local/bin is in PATH
    if ! check_path; then
        echo -e "${YELLOW}Note:${NC} Add ~/.local/bin to your PATH (one-time setup):"
        echo "    echo 'export PATH=\"\$HOME/.local/bin:\$PATH\"' >> ~/.zshrc && source ~/.zshrc"
        echo ""
    fi

    echo "Launch Claude with this account:"
    echo "    claudewho-${name}"
}

# Remove an account
remove_account() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo -e "${RED}Error:${NC} Account name required"
        echo "Usage: claudewho remove <name>"
        exit 1
    fi

    if ! account_exists "$name"; then
        echo -e "${RED}Error:${NC} Account '$name' not found"
        echo "Run 'claudewho list' to see available accounts."
        exit 1
    fi

    local dir="${CONFIG_DIR_PREFIX}${name}"

    echo -e "${YELLOW}Warning:${NC} This will remove account '$name'"
    if [[ -d "$dir" ]]; then
        echo "  Directory: $dir (will be deleted)"
    fi
    local wrapper_path="${WRAPPER_DIR}/claudewho-${name}"
    if [[ -f "$wrapper_path" ]]; then
        echo "  Command: $wrapper_path (will be deleted)"
    fi
    echo ""
    read -rp "Are you sure? [y/N] " confirm

    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi

    # Remove directory if it exists
    if [[ -d "$dir" ]]; then
        rm -rf "$dir"
        echo -e "${GREEN}Removed${NC} $dir"
    fi

    # Remove wrapper script
    remove_wrapper "$name"
    echo -e "${GREEN}Removed${NC} ${WRAPPER_DIR}/claudewho-${name}"

    # Remove from config (create temp file without the account)
    local tmp_file
    tmp_file=$(mktemp)
    grep -vx "$name" "$CONFIG_FILE" > "$tmp_file" || true
    mv "$tmp_file" "$CONFIG_FILE"

    echo -e "${GREEN}Account '$name' removed successfully!${NC}"
}

# Switch to an account
use_account() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo -e "${RED}Error:${NC} Account name required"
        echo "Usage: claudewho use <name>"
        exit 1
    fi

    if ! account_exists "$name"; then
        echo -e "${RED}Error:${NC} Account '$name' not found"
        echo "Run 'claudewho list' to see available accounts."
        exit 1
    fi

    local dir="${CONFIG_DIR_PREFIX}${name}"

    if [[ ! -d "$dir" ]]; then
        echo -e "${YELLOW}Warning:${NC} Creating missing directory $dir"
        mkdir -p "$dir"
    fi

    # Ensure claude wrapper exists
    create_claude_wrapper

    # Save current account
    echo "$name" > "$CURRENT_ACCOUNT_FILE"

    echo -e "${GREEN}Switched to${NC} ${BLUE}$name${NC}"
    echo -e "Now using: $dir"
}

# Print shell initialization (aliases)
shell_init() {
    local accounts
    accounts=$(get_accounts)

    echo "# Claude Account Aliases (managed by claudewho)"
    echo "# Generated by: claudewho shell-init"
    echo ""

    if [[ -z "$accounts" ]]; then
        echo "# No accounts configured yet."
        echo "# Run 'claudewho add <name>' to create one."
        return 0
    fi

    while IFS= read -r name; do
        local dir="${CONFIG_DIR_PREFIX}${name}"
        echo "alias $name=\"CLAUDE_CONFIG_DIR='$dir' claude\""
    done <<< "$accounts"
}

# Main command router
main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        list|ls)
            list_accounts
            ;;
        add|create|new)
            add_account "$@"
            ;;
        remove|delete|rm)
            remove_account "$@"
            ;;
        use|run|launch)
            use_account "$@"
            ;;
        shell-init|init|aliases)
            shell_init
            ;;
        version|-v|--version)
            echo "claudewho $VERSION"
            ;;
        help|-h|--help)
            usage
            ;;
        *)
            echo -e "${RED}Error:${NC} Unknown command '$cmd'"
            echo "Run 'claudewho help' for usage information."
            exit 1
            ;;
    esac
}

main "$@"
